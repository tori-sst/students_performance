<?php
// Это пример файла настроек. 
// Создайте копию этого файла с именем login.php и введите свои данные.

$host = 'localhost';          // Обычно localhost
$data = 'student_performance'; // Имя вашей базы данных
$user = 'root';               // Ваше имя пользователя (в XAMPP это root)
$pass = 'ВАШ_ПАРОЛЬ';         // Ваш пароль (в XAMPP по умолчанию пусто '')
$chrs = 'utf8mb4';

$attr = "mysql:host=$host;dbname=$data;charset=$chrs";
$opts = [
    PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
    PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
    PDO::ATTR_EMULATE_PREPARES   => false,
];

try {
    $pdo = new PDO($attr, $user, $pass, $opts);
} catch (PDOException $e) {
    throw new PDOException($e->getMessage(), (int)$e->getCode());
}
?>
